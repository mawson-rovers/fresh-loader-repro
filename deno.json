{
    "tasks": {
        "test": "deno test -A",
        "check": "deno fmt --check && deno lint && deno check"
    },
    "imports": {
        "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.1.2",
        "@deno/loader": "jsr:@deno/loader@0.4.0",
        "@std/assert": "jsr:@std/assert@1.0.19",
        "@std/path": "jsr:@std/path@1.1.5"
    },
    "compilerOptions": {
        "lib": [ "deno.ns", "dom" ]
    },
    "fmt": {
        "indentWidth": 4,
        "lineWidth": 120,
        "semiColons": false,
        "singleQuote": true
    },
    "nodeModulesDir": "auto"
}
